# Copy this to `.env.local` (gitignored) and edit. Vite inlines anything that
# starts with VITE_ into the client bundle at build time, so do NOT put real
# secrets here — the values are visible in the browser.

# Default API key sent as X-API-Key. Should match API_KEY in backend/.env.
# In production, set this in your hosting provider's env vars
# (e.g. Cloud Run --set-env-vars / --set-secrets, or as a --build-arg
# baked into the frontend container image).
VITE_API_KEY=

# Optional. Default API base URL. Leave blank to use the same origin (correct
# for production deployments where the frontend and backend share a domain).
VITE_API_BASE_URL=

# Optional local-dev overrides for the Vite proxy target. Defaults: 8000.
# VITE_BACKEND_PORT=8000
# VITE_BACKEND_URL=http://127.0.0.1:8000
